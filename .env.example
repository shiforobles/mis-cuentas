# Supabase — copiá este archivo a .env y completá con tus credenciales.
# La clave pública del cliente es segura para el browser SIEMPRE con RLS activado
# (no la metemos en el código igual, va por env var). NO commitees el .env real.
#
# Soporta el formato NUEVO (publishable key: sb_publishable_...) y la anon key
# legacy (eyJ...). Podés usar cualquiera de los dos nombres de variable:
#   - VITE_SUPABASE_PUBLISHABLE_KEY  (recomendado para el formato nuevo)
#   - VITE_SUPABASE_ANON_KEY         (también aceptado)
#
# En GitHub Actions, cargá la URL y la clave como Secrets del repo
# (Settings → Secrets and variables → Actions) con el mismo nombre que uses.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_TU_CLAVE
